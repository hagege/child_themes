{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "title": "Werbegemeinschaft Eilendorf",
  "description": "WordPress Block Theme für Werbegemeinschaft",
  "settings": {
    "color": {
      "palette": [
        {
          "name": "Primär Rot",
          "slug": "primary-red",
          "color": "#E3001B"
        },
        {
          "name": "Text Dark",
          "slug": "text-dark",
          "color": "#666666"
        },
        {
          "name": "Text Dunkel",
          "slug": "text-dunkel",
          "color": "#333333"
        },
        {
          "name": "Weiß",
          "slug": "white",
          "color": "#FFFFFF"
        },
        {
          "name": "Hell-Grau",
          "slug": "light-gray",
          "color": "#F5F5F5"
        },
        {
          "name": "Dunkel-Grau",
          "slug": "dark-gray",
          "color": "#CCCCCC"
        }
      ],
      "gradients": [
        {
          "name": "Rot zu Weiß",
          "slug": "red-to-white",
          "gradient": "linear-gradient(90deg, #E3001B, #FFFFFF)"
        },
        {
          "name": "Weiß zu Grau",
          "slug": "white-to-gray",
          "gradient": "linear-gradient(90deg, #FFFFFF, #F5F5F5)"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "name": "Inter",
          "slug": "inter",
          "fontFamily": "Inter, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif"
        }
      ],
      "fontSizes": [
        {
          "name": "Klein",
          "slug": "small",
          "size": "0.875rem"
        },
        {
          "name": "Normal",
          "slug": "normal",
          "size": "1rem"
        },
        {
          "name": "Groß",
          "slug": "large",
          "size": "1.25rem"
        },
        {
          "name": "Überschrift 3",
          "slug": "h3",
          "size": "1.5rem"
        },
        {
          "name": "Überschrift 2",
          "slug": "h2",
          "size": "2.25rem"
        },
        {
          "name": "Überschrift 1",
          "slug": "h1",
          "size": "3rem"
        }
      ]
    },
    "spacing": {
      "units": [
        "px",
        "em",
        "rem",
        "%",
        "vw",
        "vh"
      ]
    },
    "custom": {
      "brand": {
        "primary-red": "#E3001B",
        "text-dark": "#333333",
        "text": "#666666",
        "white": "#FFFFFF",
        "light-gray": "#F5F5F5",
        "dark-gray": "#CCCCCC"
      },
      "spacing": {
        "xs": "0.75rem",
        "sm": "1rem",
        "md": "2rem",
        "lg": "3rem"
      },
      "radius": {
        "small": "0.25rem",
        "base": "0.5rem"
      },
      "transition": "all 0.2s ease"
    }
  },
  "styles": {
    "color": {
      "background": "var(--wp--preset--color--white)",
      "text": "var(--wp--preset--color--text-dark)"
    },
    "typography": {
      "fontFamily": "var(--wp--preset--font-family--inter)",
      "lineHeight": "1.6"
    },
    "elements": {
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--text-dunkel)"
        },
        "typography": {
          "fontWeight": "700"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h1)",
          "fontWeight": "700",
          "lineHeight": "1.2"
        },
        "color": {
          "text": "var(--wp--preset--color--text-dunkel)"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h2)",
          "fontWeight": "700",
          "lineHeight": "1.3"
        },
        "color": {
          "text": "var(--wp--preset--color--text-dunkel)"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--h3)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        },
        "color": {
          "text": "var(--wp--preset--color--text-dunkel)"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--large)",
          "fontWeight": "600",
          "lineHeight": "1.4"
        },
        "color": {
          "text": "var(--wp--preset--color--text-dunkel)"
        }
      },
      "link": {
        "color": {
          "text": "var(--wp--preset--color--primary-red)"
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--text-dark)"
          }
        },
        ":focus-visible": {
          "outline": "2px solid var(--wp--preset--color--primary-red)",
          "outlineOffset": "2px"
        }
      },
      "button": {
        "color": {
          "background": "var(--wp--preset--color--primary-red)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontWeight": "600"
        },
        "padding": {
          "top": "0.75rem",
          "right": "1rem",
          "bottom": "0.75rem",
          "left": "1rem"
        },
        "border": {
          "radius": "0.25rem"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--text-dark)"
          }
        }
      }
    },
    "blocks": {
      "core/button": {
        "color": {
          "background": "var(--wp--preset--color--primary-red)",
          "text": "var(--wp--preset--color--white)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--normal)",
          "fontWeight": "600"
        },
        "spacing": {
          "padding": {
            "top": "0.75rem",
            "right": "1rem",
            "bottom": "0.75rem",
            "left": "1rem"
          }
        },
        "border": {
          "radius": "0.25rem"
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--text-dark)"
          }
        },
        ":focus-visible": {
          "outline": "2px solid var(--wp--preset--color--text-dunkel)",
          "outlineOffset": "3px"
        }
      },
      "core/heading": {
        "color": {
          "text": "var(--wp--preset--color--text-dunkel)"
        }
      },
      "core/paragraph": {
        "color": {
          "text": "var(--wp--preset--color--text-dark)"
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--normal)",
          "lineHeight": "1.6"
        }
      },
      "core/group": {
        "spacing": {
          "padding": {
            "top": "2rem",
            "right": "2rem",
            "bottom": "2rem",
            "left": "2rem"
          }
        }
      },
      "core/columns": {
        "spacing": {
          "margin": {
            "top": "0",
            "bottom": "0"
          }
        }
      },
      "core/image": {
        "border": {
          "radius": "0.25rem"
        }
      }
    }
  }
}