{
  "$schema": "https://schemas.wp.org/wp/6.9/theme.json",
  "version": 3,
  "settings": {
    "color": {
      "palette": [
        {
          "color": "#151A52",
          "name": "GSG Navy",
          "slug": "gsg-navy"
        },
        {
          "color": "#2B4B6F",
          "name": "GSG Blue",
          "slug": "gsg-blue"
        },
        {
          "color": "#C1C5CD",
          "name": "GSG Gray",
          "slug": "gsg-gray"
        },
        {
          "color": "#E8EAED",
          "name": "GSG Light Gray",
          "slug": "gsg-light-gray"
        },
        {
          "color": "#F1F3F4",
          "name": "GSG Cool Light Gray",
          "slug": "gsg-cool-light-gray"
        },
        {
          "color": "#EEC849",
          "name": "GSG Yellow",
          "slug": "gsg-yellow"
        },
        {
          "color": "#D4A017",
          "name": "GSG Gold",
          "slug": "gsg-gold"
        },
        {
          "color": "#ffffff",
          "name": "White",
          "slug": "base"
        },
        {
          "color": "#000000",
          "name": "Black",
          "slug": "contrast"
        },
        {
          "color": "#22C55E",
          "name": "Success Green",
          "slug": "gsg-success"
        },
        {
          "color": "#3B82F6",
          "name": "Info Blue",
          "slug": "gsg-info"
        },
        {
          "color": "#F59E0B",
          "name": "Warning Orange",
          "slug": "gsg-warning"
        }
      ]
    },
    "patterns": {
      "categories": [
        {
          "name": "gsg",
          "label": "gsg"
        }
      ]
    },
    "layout": {
      "contentSize": "1024px",
      "wideSize": "1920px"
    },
    "typography": {
      "customFontSize": true,
      "dropCap": true,
      "fontFamilies": [
        {
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "name": "Inter (System Fallback)",
          "slug": "inter"
        },
        {
          "fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "name": "System Sans-Serif",
          "slug": "system"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "size": "0.875rem",
          "slug": "small"
        },
        {
          "name": "Medium",
          "size": "1rem",
          "slug": "medium"
        },
        {
          "name": "Large",
          "size": "1.125rem",
          "slug": "large"
        },
        {
          "name": "Extra Large",
          "size": "1.5rem",
          "slug": "x-large"
        },
        {
          "name": "Heading Small",
          "size": "1.8rem",
          "slug": "heading-small"
        },
        {
          "name": "Heading Medium",
          "size": "2.5rem",
          "slug": "heading-medium"
        },
        {
          "name": "Heading Large",
          "size": "3.5rem",
          "slug": "heading-large"
        },
        {
          "fluid": {
            "max": "4rem",
            "min": "2.5rem"
          },
          "name": "Hero",
          "size": "clamp(2.5rem, 6vw, 4rem)",
          "slug": "hero"
        }
      ],
      "fontStyle": true,
      "fontWeight": true,
      "letterSpacing": true,
      "textDecoration": true,
      "textTransform": true
    },
    "useRootPaddingAwareAlignments": true
  },
  "styles": {
    "blocks": {
      "core/button": {
        "border": {
          "radius": "8px"
        },
        "spacing": {
          "padding": {
            "bottom": "1rem",
            "left": "2rem",
            "right": "2rem",
            "top": "1rem"
          }
        },
        "variations": {
          "outline": {
            "border": {
              "color": "var(--wp--preset--color--gsg-navy)",
              "radius": "8px",
              "style": "solid",
              "width": "2px"
            },
            "color": {
              "background": "transparent",
              "text": "var(--wp--preset--color--gsg-navy)"
            },
            "spacing": {
              "padding": {
                "bottom": "calc(1rem - 2px)",
                "left": "calc(2rem - 2px)",
                "right": "calc(2rem - 2px)",
                "top": "calc(1rem - 2px)"
              }
            }
          }
        }
      },
      "core/columns": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--50)"
        }
      },
      "core/group": {
        "spacing": {
          "blockGap": "var(--wp--preset--spacing--50)"
        }
      },
      "core/image": {
        "border": {
          "radius": "var(--wp--custom--gsg--border-radius--medium)"
        }
      },
      "core/navigation": {
        "typography": {
          "fontWeight": "500"
        },
        "spacing": {
          "padding": {
            "top": "0.5rem",
            "right": "0.5rem",
            "bottom": "0.5rem",
            "left": "0.5rem"
          }
        }
      },
      "core/quote": {
        "border": {
          "color": "var(--wp--preset--color--gsg-yellow)",
          "style": "solid",
          "width": "0 0 0 4px"
        },
        "color": {
          "background": "var(--wp--preset--color--gsg-light-gray)"
        },
        "spacing": {
          "padding": {
            "bottom": "var(--wp--preset--spacing--50)",
            "left": "var(--wp--preset--spacing--60)",
            "right": "var(--wp--preset--spacing--50)",
            "top": "var(--wp--preset--spacing--50)"
          }
        }
      },
      "core/separator": {
        "color": {
          "background": "var(--wp--preset--color--gsg-gray)"
        }
      },
      "core/table": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--small)"
        }
      }
    },
    "color": {
      "background": "var(--wp--preset--color--base)",
      "text": "var(--wp--preset--color--contrast)"
    },
    "css": ".gruppe-mit-cover {\n    overflow: hidden;\n}\n\n/* Einstellungen Cover übernehmen */\n@media (min-width: 960px) {\n    div.header-cover {\n        min-height: 80vh !important;\n        aspect-ratio: unset !important;\n    }\n}\n\n/* Problem bei Firefox auf der Startpage */\n.wp-block-image.alignfull.size-full.wave_startpage_image img,\n.wp-block-image.alignfull.size-full.wave_image img {\n    height: 9rem;\n}\n\n/* Überschrift h2 als Link  */\nh2.link-in-card a {\n    font-family: 'Finger Paint';\n    text-decoration: none;\n    line-height: 1.6;\n}\n\n\n/* Buttons */\n/* roter Button mit rotem Outline bei Hover */\n/* Buttons */\n/* roter Button mit rotem Outline bei Hover */\ndiv.roter_button a:hover,\ndiv.roter_button a:focus,\ndiv.roter_button a:active\n{\n    outline-color: var(--wp--preset--color--custom-dunkelrot);\n}\n\n\n/* grüner Button mit grünem Outline bei Hover */\ndiv.gruener_button a:hover,\ndiv.gruener_button a:focus,\ndiv.gruener_button a:active\n{\n    outline-color: var(--wp--preset--color--custom-mittelgr-n);\n}\n\n/* Desktop Menü */\n/* Menü bei hover */\n/* Logo nicht bei Hover hervorheben */\n.wp-block-site-logo a:hover { \n   text-decoration: none;\n   background-color: inherit;\n}\n\n/* alle Links außer Buttons */\na:where(:not(.wp-element-button)) {\n    text-underline-offset: 7px;\n    transition: all .2s;\n    text-decoration: underline;\n    text-decoration-thickness: 1px;\n}\n\na:where(:not(.wp-element-button)):hover {\n    text-underline-offset: 10px;\n    text-decoration-thickness: 2px;\n}\n\n.wp-block-navigation a:where(:not(.wp-element-button)) {\n    text-decoration: none;\n    padding: 0.3em 0.5em;\n    text-decoration: none;\n}\n\n/* Links in Navigation */\n.wp-block-navigation a:where(:not(.wp-element-button)):hover {\n    text-decoration: none;\n    background-color: var(--wp--preset--color--custom-dunkelrot) !important;\n    color: var(--wp--preset--color--custom-weiss) !important;\n}\n\n.wp-block-navigation a:where(:not(.wp-element-button)):focus,\n.wp-block-navigation a:where(:not(.wp-element-button)):active {\n    text-decoration: none;\n    background-color: var(--wp--preset--color--custom-mittelgr-n) !important;\n    color: var(--wp--preset--color--custom-weiss) !important;\n    outline: 2px;\n}\n\n\n/* nicht mehr verwendet */\n/* language switcher \nh2.widgettitle {\n    font-size: medium;\n    font-family: 'Lexend';\n    text-align: center;\n    visibility: hidden;\n    display:none;\n}\n\ndiv.widget_polylang ul {\n  list-style-type: none;\n}\n*/",
    "elements": {
      "button": {
        ":active": {
          "color": {
            "background": "var(--wp--preset--color--gsg-gold)",
            "text": "var(--wp--preset--color--gsg-navy)"
          },
          "shadow": "var(--wp--preset--shadow--gsg-sm)"
        },
        ":focus": {
          "color": {
            "background": "var(--wp--preset--color--gsg-gold)",
            "text": "var(--wp--preset--color--gsg-navy)"
          },
          "outline": {
            "color": "var(--wp--preset--color--base)",
            "offset": "3px",
            "style": "solid",
            "width": "3px"
          }
        },
        ":hover": {
          "color": {
            "background": "var(--wp--preset--color--gsg-gold)",
            "text": "var(--wp--preset--color--gsg-navy)"
          },
          "outline": {
            "color": "var(--wp--preset--color--base)",
            "offset": "3px",
            "style": "solid",
            "width": "3px"
          },
          "shadow": "0 6px 20px rgba(229, 181, 51, 0.4)"
        },
        "border": {
          "radius": "8px",
          "width": "0px"
        },
        "color": {
          "background": "var(--wp--preset--color--gsg-yellow)",
          "text": "var(--wp--preset--color--gsg-navy)"
        },
        "shadow": "var(--wp--preset--shadow--gsg-md)",
        "spacing": {
          "padding": {
            "bottom": "1rem",
            "left": "2rem",
            "right": "2rem",
            "top": "1rem"
          }
        },
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "fontWeight": "600",
          "lineHeight": "1.5"
        }
      },
      "h1": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--hero)",
          "fontWeight": "800",
          "lineHeight": "1.1"
        }
      },
      "h2": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-medium)",
          "lineHeight": "1.2"
        }
      },
      "h3": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--heading-small)",
          "lineHeight": "1.3"
        }
      },
      "h4": {
        "typography": {
          "fontSize": "var(--wp--preset--font-size--x-large)",
          "lineHeight": "1.4"
        }
      },
      "heading": {
        "color": {
          "text": "var(--wp--preset--color--gsg-navy)"
        },
        "typography": {
          "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
          "fontWeight": "700",
          "lineHeight": "1.2"
        }
      },
      "link": {
        ":focus": {
          "color": {
            "text": "var(--wp--preset--color--gsg-navy)"
          },
          "outline": {
            "color": "var(--wp--preset--color--gsg-yellow)",
            "offset": "3px",
            "style": "solid",
            "width": "3px"
          }
        },
        ":hover": {
          "color": {
            "text": "var(--wp--preset--color--gsg-blue)"
          }
        },
        "color": {
          "text": "var(--wp--preset--color--gsg-navy)"
        }
      }
    },
    "spacing": {
      "blockGap": "var(--wp--preset--spacing--50)",
      "padding": {
        "bottom": "var(--wp--preset--spacing--50)",
        "left": "var(--wp--preset--spacing--50)",
        "right": "var(--wp--preset--spacing--50)",
        "top": "var(--wp--preset--spacing--50)"
      }
    },
    "typography": {
      "fontFamily": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif",
      "fontSize": "var(--wp--preset--font-size--x-large)",
      "lineHeight": "1.6"
    }
  }
}